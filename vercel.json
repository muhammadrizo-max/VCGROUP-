{
  "version": 2,
  "name": "visioncoregroup",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/projects", "dest": "/projects.html" },
    { "src": "/bots", "dest": "/bots.html" },
    { "src": "/team", "dest": "/team.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/admin", "dest": "/admin.html" }
  ]
}
